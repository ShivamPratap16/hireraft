# Optional: set to "true" and provide a script URL to load third-party analytics (e.g. Plausible, PostHog loader).
# VITE_ENABLE_ANALYTICS=true
# VITE_ANALYTICS_SCRIPT_URL=https://plausible.io/js/script.js

# Optional: canonical site URL for Open Graph (defaults to https://jobpilot.app in index.html if unset at build time)
# VITE_SITE_URL=https://your-domain.com
#
# Landing hero: add public/marketing/dashboard-preview.png for a real screenshot (optional; CSS fallback if missing).
# Social preview image: public/marketing/og-card.svg (referenced from index.html og:image — update domain to match deploy).
